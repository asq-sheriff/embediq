{
  "name": "embediq",
  "version": "3.2.0",
  "description": "EmbedIQ by Praglogic — Adaptive wizard that generates production-ready AI coding agent configurations across Claude Code, Cursor, GitHub Copilot, Gemini, Windsurf, and AGENTS.md from a single interview.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "start:web": "tsx src/web/server.ts",
    "dev": "tsx watch src/index.ts",
    "dev:web": "tsx watch src/web/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:snapshots": "vitest run --update",
    "evaluate": "tsx src/evaluation/cli.ts",
    "benchmark": "tsx src/evaluation/cli.ts --mode benchmark",
    "drift": "tsx src/autopilot/cli.ts",
    "sanitize-public": "tsx scripts/sanitize-for-public.ts",
    "docs-lint": "tsx scripts/docs-lint.ts"
  },
  "keywords": [
    "claude-code",
    "setup",
    "wizard",
    "configuration"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@opentelemetry/api": "^1.9.1",
    "chalk": "^5.3.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "ws": "^8.20.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.4",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "optionalDependencies": {
    "@opentelemetry/exporter-metrics-otlp-http": "^0.200.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.200.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.200.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "better-sqlite3": "^12.9.0"
  }
}

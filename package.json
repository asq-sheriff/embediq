{
  "name": "embediq",
  "version": "2.0.0",
  "description": "EmbedIQ by Praglogic — Adaptive wizard that generates ideal Claude Code configurations",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "embediq": "dist/index.js",
    "embediq-web": "dist/web/server.js"
  },
  "files": [
    "dist/",
    "templates/",
    "plugins/README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "tsx src/index.ts",
    "start:web": "tsx src/web/server.ts",
    "dev": "tsx watch src/index.ts",
    "dev:web": "tsx watch src/web/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:snapshots": "vitest run --update"
  },
  "keywords": [
    "claude-code",
    "claude",
    "ai",
    "setup",
    "wizard",
    "configuration",
    "hipaa",
    "pci-dss",
    "ferpa",
    "compliance",
    "devtools"
  ],
  "author": "Praglogic <aejaz.sheriff@pragmaticlogic.ai>",
  "homepage": "https://github.com/asq-sheriff/embediq",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asq-sheriff/embediq.git"
  },
  "bugs": {
    "url": "https://github.com/asq-sheriff/embediq/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
